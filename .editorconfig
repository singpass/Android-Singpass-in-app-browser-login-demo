root = true

[*.{kt,kts}]
ktlint_code_style = android_studio # intellij_idea, android_studio or ktlint_official (default)

# ktlint_disabled_rules=no-trailing-spaces,no-multi-spaces,no-empty-first-line-in-method-block,multiline-if-else,trailing-comma-on-call-site, trailing-comma-on-declaration-site

ktlint_experimental = disabled # Disables all `experimental` rules from all rule sets provided by KtLint or other rule providers
ktlint_standard_final-newline = disabled # Disables the `final-newline` rule provided by KtLint
ktlint_standard_no-trailing-spaces = disabled # Disables the `no-trailing-spaces` rule provided by KtLint
ktlint_standard_no-multi-spaces = disabled # Disables the `no-multi-spaces` rule provided by KtLint
ktlint_standard_no-empty-first-line-in-method-block = disabled # Disables the `no-empty-first-line-in-method-block` rule provided by KtLint
ktlint_standard_multiline-if-else = disabled # Disables the `multiline-if-else` rule provided by KtLint
ktlint_standard_trailing-comma-on-call-site = disabled # Disables the `trailing-comma-on-call-site` rule provided by KtLint
ktlint_standard_trailing-comma-on-declaration-site = disabled # Disables the `trailing-comma-on-declaration-site` rule provided by KtLint
ktlint_standard_package-name = disabled # Disables the `package-name` rule provided by KtLint
ktlint_standard_property-naming = disabled
ktlint_standard_class-naming = disabled
ktlint_standard_function-naming = disabled
ktlint_standard_argument-list-wrapping = disabled
ktlint_standard_function-signature = disabled
ktlint_standard_value-parameter-comment = disabled
ktlint_standard_value-argument-comment = disabled
ktlint_standard_statement-wrapping = disabled
ktlint_standard_class-signature = disabled
ktlint_standard_function-expression-body = disabled
ktlint_standard_function-literal = disabled
ktlint_standard_backing-property-naming = disabled
ktlint_standard_blank-line-between-when-conditions = disabled

# possible values: number (e.g. 2), "unset" (makes ktlint ignore indentation completely)
indent_size=4
# ktlint plugin has issues auto-formatting tabs to spaces
# Even after running Android Studio auto-format to tabs,
#   ktlintCheck will still fail the indent checks
# So leaving indent style as `space`
indent_style=space
max_line_length=150

[{**/test*/**.kt,**/*Dao.kt,**/*DB.kt,**/build.gradle.kts}]
ktlint_code_style = android_studio # intellij_idea, android_studio or ktlint_official (default)
# String literals will trigger a max line length failure
# OFF for tests (String data inputs)
# OFF for Dao / DB (SQL statements)
# OFF for app/build.gradle.kts (String buildConfig fields)
max_line_length=off
